---
import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import type { Widget } from '~/types';

export interface Proyecto {
  titulo: string;
  descripcion: string;
  antes: string;
  despues: string;
}

export interface Props extends Widget {
  title?: string;
  subtitle?: string;
  tagline?: string;
  proyectos: Proyecto[];
}

const { title, subtitle, tagline, proyectos = [], id, isDark = false, bg } = Astro.props;
---

<WidgetWrapper id={id} isDark={isDark} containerClass="max-w-7xl mx-auto" bg={bg}>
  <Headline title={title} subtitle={subtitle} tagline={tagline} />

  <div class="grid gap-8 sm:grid-cols-2">
    {
      proyectos.map((p) => (
        <div class="rounded-2xl overflow-hidden bg-white dark:bg-slate-900 shadow-lg border border-gray-100 dark:border-slate-800">
          <div class="grid grid-cols-2">
            <div class="relative">
              <img src={p.antes} alt={`Antes: ${p.titulo}`} class="h-48 w-full object-cover sm:h-56" loading="lazy" />
              <span class="absolute bottom-2 left-2 rounded bg-black/70 px-2 py-0.5 text-xs font-medium text-white">
                Antes
              </span>
            </div>
            <div class="relative">
              <img
                src={p.despues}
                alt={`Después: ${p.titulo}`}
                class="h-48 w-full object-cover sm:h-56"
                loading="lazy"
              />
              <span class="absolute bottom-2 right-2 rounded bg-secondary px-2 py-0.5 text-xs font-semibold text-white">
                Después
              </span>
            </div>
          </div>
          <div class="p-6">
            <h3 class="text-lg font-bold dark:text-white">{p.titulo}</h3>
            <p class="mt-2 text-muted dark:text-slate-400">{p.descripcion}</p>
          </div>
        </div>
      ))
    }
  </div>
</WidgetWrapper>

---
import type { Form as Props } from '~/types';
import Button from '~/components/ui/Button.astro';

const {
  inputs,
  textarea,
  disclaimer,
  button = 'Enviar',
  description = '',
  formName = 'Formulario',
  successMessage = '¡Mensaje enviado correctamente! Te contactaremos lo antes posible.',
} = Astro.props;

const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY || '';
---

<form class="js-web3form" data-success-message={successMessage} data-button-label={button}>
  <input type="hidden" name="access_key" value={web3formsKey} />
  <input type="hidden" name="subject" value={`Nuevo mensaje (${formName}) desde la web`} />
  <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

  {
    inputs &&
      inputs.map(
        ({ type = 'text', name, label = '', autocomplete = 'on', placeholder = '' }) =>
          name && (
            <div class="mb-6">
              {label && (
                <label for={name} class="block text-sm font-medium">
                  {label}
                </label>
              )}
              <input
                type={type}
                name={name}
                id={name}
                autocomplete={autocomplete}
                placeholder={placeholder}
                required
                class="py-3 px-4 block w-full text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900"
              />
            </div>
          )
      )
  }

  {
    textarea && (
      <div>
        <label for="textarea" class="block text-sm font-medium">
          {textarea.label}
        </label>
        <textarea
          id="textarea"
          name={textarea.name ? textarea.name : 'message'}
          rows={textarea.rows ? textarea.rows : 4}
          placeholder={textarea.placeholder}
          required
          class="py-3 px-4 block w-full text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900"
        />
      </div>
    )
  }

  {
    disclaimer && (
      <div class="mt-3 flex items-start">
        <div class="flex mt-0.5">
          <input
            id="disclaimer"
            name="disclaimer"
            type="checkbox"
            required
            class="cursor-pointer mt-1 py-3 px-4 block w-full text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900"
          />
        </div>
        <div class="ml-3">
          <label for="disclaimer" class="cursor-pointer select-none text-sm text-gray-600 dark:text-gray-400">
            {disclaimer.label}
          </label>
        </div>
      </div>
    )
  }

  {
    button && (
      <div class="mt-10 grid">
        <Button variant="primary" type="submit">
          {button}
        </Button>
      </div>
    )
  }

  <div class="form-feedback mt-4 text-center text-sm hidden" role="status"></div>

  {
    description && (
      <div class="mt-3 text-center">
        <p class="text-sm text-gray-600 dark:text-gray-400">{description}</p>
      </div>
    )
  }
</form>

<script>
  // Envía el formulario a Web3Forms (https://web3forms.com) sin recargar la página.
  // La clave se configura en la variable de entorno PUBLIC_WEB3FORMS_KEY (ver .env.example).
  document.querySelectorAll<HTMLFormElement>('form.js-web3form').forEach((form) => {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const boton = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const feedback = form.querySelector<HTMLDivElement>('.form-feedback');
      const accessKeyInput = form.querySelector<HTMLInputElement>('input[name="access_key"]');
      const accessKey = accessKeyInput?.value;
      const successMessage = form.dataset.successMessage || 'Mensaje enviado correctamente.';
      const originalLabel = form.dataset.buttonLabel || boton?.textContent || 'Enviar';

      const mostrarMensaje = (texto: string, tipo: 'exito' | 'error') => {
        if (!feedback) return;
        feedback.textContent = texto;
        feedback.classList.remove('hidden', 'text-green-600', 'text-red-600');
        feedback.classList.add(tipo === 'exito' ? 'text-green-600' : 'text-red-600');
      };

      if (!accessKey) {
        mostrarMensaje(
          'Falta configurar la clave de Web3Forms (PUBLIC_WEB3FORMS_KEY) en el archivo .env.',
          'error'
        );
        return;
      }

      if (boton) {
        boton.disabled = true;
        boton.textContent = 'Enviando...';
      }

      try {
        const formData = new FormData(form);
        const respuesta = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: formData,
        });
        const resultado = await respuesta.json();

        if (resultado.success) {
          mostrarMensaje(successMessage, 'exito');
          form.reset();
        } else {
          throw new Error(resultado.message || 'Error desconocido');
        }
      } catch (error) {
        mostrarMensaje('No se pudo enviar el mensaje. Inténtalo de nuevo o llama por teléfono.', 'error');
      } finally {
        if (boton) {
          boton.disabled = false;
          boton.textContent = originalLabel;
        }
      }
    });
  });
</script>
